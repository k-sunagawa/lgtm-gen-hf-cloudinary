# Hugging Face Token（サーバー起動時に読み込み、ブラウザには渡しません）
# https://huggingface.co/settings/tokens で取得（Read 権限のみでOK）
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudinary（画像アップロード用）
# https://cloudinary.com でアカウント作成後、Settings > Upload > Upload presets で設定
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=preset_name

# Cloudinary Admin API（他環境でアップロードした画像の一覧取得用）
# Settings > API Keys で取得。hasCloudinaryAdmin が有効になる
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
